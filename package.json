{
  "name": "makechurcheasy",
  "private": true,
  "version": "2.11.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "generate:embeddings": "node scripts/generate-bible-embeddings.cjs",
    "sync:local-llm-model": "node scripts/sync-local-llm-model.cjs",
    "version:patch": "npm version patch --no-git-tag-version ",
    "version:minor": " npm run build  && npm version minor --no-git-tag-version &&  node scripts/sync-version.cjs",
    "version:major": "npm run build  && npm version major --no-git-tag-version && node scripts/sync-version.cjs",
    "release:patch": "npm run version:patch && git add . && git commit -m \"v$(node -p \"require('./package.json').version\")\" && git push",
    "release:minor": "npm run version:minor && git add . && git commit -m \"v$(node -p \"require('./package.json').version\")\" && git push",
    "release:major": "npm run version:major && git add . && git commit -m \"v$(node -p \"require('./package.json').version\")\" && git push",
    "latest": " node scripts/generate-update-json.cjs"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.6",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "^2.2.0",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@types/qrcode": "^1.5.6",
    "@xenova/transformers": "^2.17.2",
    "docx": "^9.7.1",
    "file-saver": "^2.0.5",
    "fuse.js": "^7.4.2",
    "idb": "^8.0.3",
    "jspdf": "^4.2.1",
    "konva": "^10.2.0",
    "lucide-react": "^0.577.0",
    "nanoid": "^5.1.6",
    "obs-websocket-js": "^5.0.7",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-colorful": "^5.7.0",
    "react-dom": "^19.1.0",
    "react-konva": "^19.2.2",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/file-saver": "^2.0.7",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vercel": "^54.12.2",
    "vite": "^7.0.4",
    "vitest": "^4.1.8"
  }
}
