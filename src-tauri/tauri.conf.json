{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MakeChurchEasy",
  "version": "2.25.0",
  "identifier": "com.makechurcheasy.app",
  "build": {
    "beforeDevCommand": "node scripts/prepare-bundle-assets.cjs && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node scripts/prepare-bundle-assets.cjs && npm run build",
    "beforeBundleCommand": "node scripts/prepare-bundle-assets.cjs",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MakeChurchEasy",
        "width": 1280,
        "height": 820,
        "minWidth": 800,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: data: blob:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' asset: data: blob: http://127.0.0.1:* http://localhost:* https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:* wss://streaming.assemblyai.com https://api.github.com https://github.com https://versecast-bible-api.solitary-credit-34b2.workers.dev https://*.r2.cloudflarestorage.com https://*.r2.dev https://*.workers.dev https://app.posthog.com https://us.i.posthog.com http://localhost:4000 https://accounts.google.com https://graph.facebook.com https://api.makechurcheasy.creatorstudioslabs.stream https://*.vercel.app;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": [
      "../dist/bible-overlay-fullscreen.html",
      "../dist/bible-overlay-lower-third.html",
      "../dist/bible-overlay-bg.html",
      "../dist/bible-kjv.json",
      "../dist/lower-third-overlay.html",
      "../dist/pre-service-countdown.html",
      "../dist/pre-service-media.html",
      "../dist/dock.html",
      "../dist/lm-dock.html",
      "../dist/animated-lower-thirds/**/*",
      "../dist/assets/**/*",
      "../dist/fonts/**/*"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "windows-installer-hooks.nsh"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "entitlements.plist",
      "infoPlist": "Info.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg4QUQxNTRDNDlFOUREREUKUldUZTNlbEpUQld0aU5nRzUvU0JuWnQ0b1VNRUR5VVhYQmtvRjIyK2tYbXNxMUZwdnF4bGVkVXUK",
      "endpoints": [
        "https://github.com/jolamyfoodsng/makechurcheasy-releases/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
